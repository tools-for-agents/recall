{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.tools-for-agents/recall",
  "description": "Federated recall across an agent's brain, team, reading and code, in one budgeted query.",
  "version": "0.1.0",
  "websiteUrl": "https://tools-for-agents.github.io",
  "repository": {
    "url": "https://github.com/tools-for-agents/recall",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@tools-for-agents/recall",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ]
    }
  ]
}
